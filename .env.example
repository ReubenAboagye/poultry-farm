# Application
APP_NAME="Poultry Farm"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/farm/public

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_username
DB_PASS=your_password

# Email Configuration
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="Poultry Farm"

# SMS (Hubtel)
HUBTEL_CLIENT_ID=your_client_id
HUBTEL_CLIENT_SECRET=your_client_secret
HUBTEL_SENDER_ID=your_sender_id

# Security
SESSION_LIFETIME=120
ENCRYPTION_KEY=your-32-character-encryption-key

# Currency
DEFAULT_CURRENCY=GHS
CURRENCY_SYMBOL=₵

# File Upload
MAX_UPLOAD_SIZE=10485760 # 10MB in bytes
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Reporting
WEEKLY_REPORT_DAY=monday
REPORT_TIMEZONE=Africa/Accra

# Notification Settings
LOW_STOCK_THRESHOLD=100
SALES_MILESTONE_AMOUNT=10000
VACCINATION_REMINDER_DAYS=3

# API Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1 # minutes 