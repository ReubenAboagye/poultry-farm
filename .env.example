# Application
APP_NAME=Poultry Management System
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=poultry_farm
DB_USERNAME=root
DB_PASSWORD=

# Email
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# SMS (Hubtel)
HUBTEL_CLIENT_ID=your-client-id
HUBTEL_CLIENT_SECRET=your-client-secret
HUBTEL_SENDER_ID=your-sender-id

# Security
SESSION_LIFETIME=120
ENCRYPTION_KEY=your-32-character-encryption-key

# Currency
DEFAULT_CURRENCY=GHS
CURRENCY_SYMBOL=₵

# File Upload
MAX_UPLOAD_SIZE=10485760 # 10MB in bytes
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Reporting
WEEKLY_REPORT_DAY=monday
REPORT_TIMEZONE=Africa/Accra

# Notification Settings
LOW_STOCK_THRESHOLD=100
SALES_MILESTONE_AMOUNT=10000
VACCINATION_REMINDER_DAYS=3

# API Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_WINDOW=1 # minutes 